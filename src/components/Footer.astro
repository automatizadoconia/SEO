---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/recursos', label: 'Recursos' },
  { href: '/recomendaciones', label: 'Recomendaciones' },
  { href: '/sobre-mi', label: 'Sobre mí' },
];
---

<footer class="bg-slate-900 text-slate-300 pt-12 pb-6">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-8 border-b border-slate-700">

      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <a href="/" class="flex items-center gap-2 shrink-0 whitespace-nowrap" aria-label="AutomatizadoConIA">
          <svg width="30" height="30" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="#3B82F6"/>
            <circle cx="16" cy="16" r="5" fill="white"/>
            <circle cx="7" cy="10" r="2.5" fill="white" opacity="0.7"/>
            <circle cx="25" cy="10" r="2.5" fill="white" opacity="0.7"/>
            <circle cx="7" cy="22" r="2.5" fill="white" opacity="0.7"/>
            <circle cx="25" cy="22" r="2.5" fill="white" opacity="0.7"/>
            <line x1="11" y1="16" x2="9.5" y2="10" stroke="white" stroke-width="1.5" opacity="0.6"/>
            <line x1="21" y1="16" x2="22.5" y2="10" stroke="white" stroke-width="1.5" opacity="0.6"/>
            <line x1="11" y1="16" x2="9.5" y2="22" stroke="white" stroke-width="1.5" opacity="0.6"/>
            <line x1="21" y1="16" x2="22.5" y2="22" stroke="white" stroke-width="1.5" opacity="0.6"/>
          </svg>
          <span class="text-sm font-bold text-white leading-none whitespace-nowrap">
            Automatizado<span class="font-thin text-blue-400">ConIA</span>
          </span>
        </a>
        <p class="text-sm text-slate-400 max-w-xs leading-relaxed">
          Automatizaciones reales con IA para freelancers y pequeños negocios. Sin código innecesario.
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <h3 class="text-xs font-semibold text-white mb-4 uppercase tracking-wider">Páginas</h3>
        <ul class="flex flex-col gap-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social with SVG icons -->
      <div class="md:border-l md:border-slate-700 md:pl-8">
        <h3 class="text-xs font-semibold text-white mb-4 uppercase tracking-wider">Redes</h3>
        <div class="flex flex-col gap-3">

          <!-- YouTube -->
          <a
            href="https://youtube.com/@automatizadoconia"
            target="_blank"
            rel="noopener noreferrer"
            title="YouTube – AutomatizadoConIA"
            class="group flex items-center gap-3 text-sm text-slate-400 hover:text-white transition-colors"
            aria-label="Canal de YouTube de AutomatizadoConIA"
          >
            <span class="w-8 h-8 rounded-lg bg-slate-800 group-hover:bg-red-600 flex items-center justify-center transition-colors flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.5v-7l6.3 3.5-6.3 3.5z"/>
              </svg>
            </span>
            YouTube
          </a>

          <!-- Pinterest -->
          <a
            href="https://pinterest.com/automatizadoconia"
            target="_blank"
            rel="noopener noreferrer"
            title="Pinterest – AutomatizadoConIA"
            class="group flex items-center gap-3 text-sm text-slate-400 hover:text-white transition-colors"
            aria-label="Pinterest de AutomatizadoConIA"
          >
            <span class="w-8 h-8 rounded-lg bg-slate-800 group-hover:bg-red-600 flex items-center justify-center transition-colors flex-shrink-0">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.4 0 0 5.4 0 12c0 5.1 3.2 9.5 7.7 11.3-.1-.9-.2-2.4 0-3.4.2-.9 1.2-5 1.2-5s-.3-.6-.3-1.5c0-1.4.8-2.4 1.8-2.4.9 0 1.3.7 1.3 1.5 0 .9-.6 2.3-.9 3.6-.3 1.1.5 2 1.5 2 1.8 0 3.2-1.9 3.2-4.6 0-2.4-1.7-4.1-4.2-4.1-2.9 0-4.5 2.1-4.5 4.3 0 .8.3 1.7.7 2.2.1.1.1.2.1.4-.1.3-.2 1-.3 1.1-.1.2-.2.2-.4.1-1.4-.7-2.3-2.8-2.3-4.5 0-3.7 2.7-7.1 7.8-7.1 4.1 0 7.3 2.9 7.3 6.8 0 4-2.5 7.3-6.1 7.3-1.2 0-2.3-.6-2.7-1.3l-.7 2.7c-.3 1-.9 2.2-1.4 2.9.9.3 1.9.4 2.9.4 6.6 0 12-5.4 12-12S18.6 0 12 0z"/>
              </svg>
            </span>
            Pinterest
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/automatizadoconia"
            target="_blank"
            rel="noopener noreferrer"
            title="GitHub – AutomatizadoConIA"
            class="group flex items-center gap-3 text-sm text-slate-400 hover:text-white transition-colors"
            aria-label="GitHub de AutomatizadoConIA"
          >
            <span class="w-8 h-8 rounded-lg bg-slate-800 group-hover:bg-slate-600 flex items-center justify-center transition-colors flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.4 0 0 5.4 0 12c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12 24 5.4 18.6 0 12 0z"/>
              </svg>
            </span>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-500">
      <div class="flex flex-col sm:flex-row items-center gap-2">
        <span>© 2026 AutomatizadoConIA · Hecho con IA y algo de Python</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="#" class="hover:text-slate-300 transition-colors">Política de privacidad</a>
        <span class="text-slate-700">·</span>
        <a href="/sobre-mi" class="hover:text-slate-300 transition-colors">Sobre mí</a>
        <span class="text-slate-700">·</span>
        <a href="/recursos" class="hover:text-slate-300 transition-colors">Recursos</a>
      </div>
    </div>
  </div>
</footer>
