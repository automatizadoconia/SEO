---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const courses = [
  {
    title: 'Automatización con n8n (Nivel Pro)',
    description: 'El curso definitivo para dominar n8n desde un enfoque técnico pero práctico. Ideal si quieres montar flujos complejos para clientes.',
    category: 'n8n',
    categoryColor: 'bg-blue-100 text-blue-700',
    benefits: ['Acceso de por vida', 'Comunidad en Discord', 'Plantillas de n8n incluidas'],
    discountText: 'Usa el código "CONIA" para un 10% de descuento',
    url: '#',
    rating: 5
  },
  {
    title: 'IA Generativa para Negocios',
    description: 'Aprende a integrar OpenAI, Claude y otras IAs en flujos de trabajo reales. No es solo saber usar prompts, es saber conectarlos.',
    category: 'IA',
    categoryColor: 'bg-violet-100 text-violet-700',
    benefits: ['Enfoque 100% práctico', 'Casos de uso reales', 'Actualizaciones semanales'],
    discountText: 'Link con descuento aplicado',
    url: '#',
    rating: 5
  },
  {
    title: 'Python para el mundo real',
    description: 'Si quieres dar el salto a automatizaciones que no se pueden hacer con "no-code", este es tu curso. Directo al grano.',
    category: 'Python',
    categoryColor: 'bg-yellow-100 text-yellow-800',
    benefits: ['Sin relleno teórico', 'Scripts reutilizables', 'Mentoría incluida'],
    discountText: 'Mejor precio garantizado',
    url: '#',
    rating: 5
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Cursos de automatización con IA recomendados",
  "itemListElement": courses.map((course, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": course.title,
    "url": "https://automatizadoconia.github.io/recomendaciones"
  }))
};
---

<Layout
  title="Cursos de automatización con IA que recomiendo – Afiliado transparente | AutomatizadoConIA"
  description="Mis herramientas y cursos favoritos para aprender automatización con IA. Recomendaciones honestas y transparentes."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <Header />

  <main class="flex-1">
    <!-- Page header -->
    <section class="bg-gradient-to-br from-slate-50 to-amber-50 border-b border-slate-100 py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <span class="inline-block text-xs font-bold text-white bg-amber-500 px-3 py-1 rounded-full mb-4 shadow-sm shadow-amber-200">Recomendaciones</span>
        <h1 class="text-3xl sm:text-5xl font-bold text-slate-900 mb-4">Herramientas y Cursos</h1>
        <p class="text-slate-500 text-lg max-w-2xl leading-relaxed">Solo recomiendo lo que yo mismo uso o he probado a fondo para mis flujos de trabajo.</p>
      </div>
    </section>

    <!-- Transparency Banner -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 mt-12">
      <div class="bg-amber-50 border border-amber-200 rounded-3xl p-6 flex flex-col md:flex-row items-center gap-5">
        <div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
        </div>
        <p class="text-sm text-amber-800 leading-relaxed text-center md:text-left">
          <strong>Transparencia:</strong> Algunos de los enlaces a continuación son de afiliado. Si compras a través de ellos, yo recibo una pequeña comisión sin coste extra para ti. Esto ayuda a mantener este proyecto vivo. Gracias.
        </p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid gap-10">
        {courses.map((course) => (
          <div class="group bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col lg:flex-row items-stretch">
            <div class="lg:w-1/3 bg-gradient-to-br from-slate-50 to-slate-100 p-10 flex flex-col justify-center items-center text-center border-b lg:border-b-0 lg:border-r border-slate-100">
              <span class={`inline-block text-[10px] uppercase font-bold tracking-widest px-3 py-1 rounded-full mb-4 shadow-sm ${course.categoryColor}`}>
                {course.category}
              </span>
              <h3 class="text-xl font-bold text-slate-900 mb-4 leading-tight">{course.title}</h3>
              <div class="flex items-center gap-1 mb-6">
                {[...Array(course.rating)].map(() => (
                  <svg width="18" height="18" fill="#FBBF24" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.169L12 18.897l-7.334 3.869 1.4-8.169-5.934-5.787 8.2-1.192z"/></svg>
                ))}
              </div>
              <span class="inline-block bg-blue-50 text-blue-600 text-[11px] font-bold px-4 py-1.5 rounded-lg border border-blue-100 italic">
                {course.discountText}
              </span>
            </div>

            <div class="lg:w-2/3 p-10 flex flex-col justify-center">
              <p class="text-slate-600 mb-8 leading-relaxed italic">
                "{course.description}"
              </p>
              <div class="grid sm:grid-cols-2 gap-4 mb-10">
                {course.benefits.map(benefit => (
                  <div class="flex items-center gap-3">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                    <span class="text-sm font-medium text-slate-700">{benefit}</span>
                  </div>
                ))}
              </div>
              <a
                href={course.url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full sm:w-fit px-10 py-4 bg-primary text-white font-bold rounded-2xl hover:bg-blue-600 transition-all text-center shadow-lg hover:scale-[1.02] active:scale-95 flex items-center justify-center gap-2"
              >
                Ver curso y oferta
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Trust Section -->
      <div class="mt-24 max-w-3xl mx-auto bg-slate-50 rounded-3xl p-10 border border-slate-100 text-center">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">¿Por qué recomiendo estos cursos?</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Internet está lleno de "vendehúmos" y cursos reciclados. Estos tres son los que yo mismo he completado o utilizo como referencia para mis propios desarrollos.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Si tienes dudas sobre cuál es el mejor para tu caso concreto, escríbeme por <a href="#" class="text-blue-500 font-bold hover:underline">redes sociales</a> y te ayudaré encantado.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
