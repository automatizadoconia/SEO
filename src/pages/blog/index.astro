---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
// Sort by date descending
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(sortedPosts.map(post => post.data.category))];
---

<Layout
  title="Blog de automatización con IA – Tutoriales y guías para freelancers | AutomatizadoConIA"
  description="Tutoriales, casos de uso y guías prácticas de automatización con IA para freelancers y pequeños negocios."
>
  <Header />

  <main class="flex-1 overflow-x-hidden">
    <!-- Page header with gradient -->
    <section class="bg-gradient-to-br from-slate-50 to-blue-50 border-b border-slate-100 py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <span class="inline-block text-xs font-bold text-white bg-blue-500 px-3 py-1 rounded-full mb-4 shadow-sm shadow-blue-200">Artículos</span>
        <h1 class="text-3xl sm:text-5xl font-bold text-slate-900 mb-4">Blog</h1>
        <p class="text-slate-500 text-lg max-w-2xl leading-relaxed">Tutoriales, casos de uso y guías prácticas de automatización con IA para que tu negocio trabaje por ti.</p>

        <!-- Search Bar Placeholder -->
        <div class="mt-12 max-w-xl relative group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-400 group-focus-within:text-blue-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input
            type="text"
            placeholder="Buscar tutoriales (ej: n8n, Make, WhatsApp...)"
            class="block w-full pl-12 pr-4 py-4 bg-white border-2 border-slate-100 rounded-2xl text-slate-900 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium"
          />
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid lg:grid-cols-12 gap-12">
        <!-- Articles Grid -->
        <div class="lg:col-span-8">
          <div class="grid sm:grid-cols-2 gap-8">
            {sortedPosts.map((post) => (
              <article class="group bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
                <a href={`/blog/${post.id}`} class="block aspect-video bg-slate-100 relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-blue-500 to-violet-600 opacity-10 group-hover:scale-110 transition-transform duration-500"></div>
                  <div class="absolute top-4 left-4">
                    <span class="inline-block text-[10px] uppercase font-bold tracking-widest px-3 py-1 bg-white/90 backdrop-blur-sm rounded-full shadow-sm text-slate-900">
                      {post.data.category}
                    </span>
                  </div>
                </a>
                <div class="p-8 flex-1 flex flex-col">
                  <div class="flex items-center gap-3 text-slate-400 text-xs font-semibold mb-4">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' })}
                    </time>
                    <span>•</span>
                    <span>{post.data.readingTime}</span>
                  </div>
                  <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-blue-600 transition-colors leading-snug">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="text-slate-500 text-sm leading-relaxed mb-6 line-clamp-2">
                    {post.data.description}
                  </p>
                  <div class="mt-auto pt-6 border-t border-slate-50">
                    <a href={`/blog/${post.id}`} class="text-blue-600 font-bold text-sm inline-flex items-center gap-2 group/link">
                      Leer artículo 
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover/link:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>

          <!-- Pagination Placeholder -->
          <div class="mt-16 flex items-center justify-center gap-2">
            <button class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold text-sm shadow-md shadow-blue-100">1</button>
            <button class="w-10 h-10 rounded-xl bg-white border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition-colors">2</button>
            <button class="w-10 h-10 rounded-xl bg-white border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"></path></svg>
            </button>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:w-64 flex-shrink-0 order-1 lg:order-2">
          <div class="sticky top-24">
            <!-- Categories widget -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-7 mb-8">
              <h2 class="font-bold text-slate-900 mb-5 text-xs uppercase tracking-widest border-b border-slate-50 pb-3">Categorías</h2>
              <ul class="flex flex-col gap-1.5">
                {categories.map((cat) => (
                  <li>
                    <a
                      href="#"
                      class="group flex items-center justify-between text-sm text-slate-600 hover:text-blue-600 transition-all py-2.5 px-3 rounded-xl hover:bg-blue-50/50"
                    >
                      <span class="font-medium">{cat}</span>
                      <svg class="opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all text-blue-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- CTA widget -->
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl p-7 text-white shadow-xl shadow-blue-100 overflow-hidden relative">
              <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
              <div class="mb-5 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center backdrop-blur-sm">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                  </svg>
                </div>
              </div>
              <h3 class="font-bold text-lg mb-2 relative z-10">Pack gratuito</h3>
              <p class="text-blue-100 text-xs mb-6 font-medium leading-relaxed relative z-10">3 automatizaciones listas para importar. Únete a otros freelancers técnicos.</p>
              <a href="/recursos" class="relative z-10 block text-center text-sm font-bold bg-white text-indigo-700 px-4 py-3.5 rounded-2xl hover:bg-slate-50 transition-colors shadow-lg shadow-indigo-900/20">
                Descargar ahora
              </a>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
